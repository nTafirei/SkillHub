CREATE MEMORY TABLE PUBLIC."publication"("id" VARCHAR(40) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL PRIMARY KEY,"dateCreated" TIMESTAMP NOT NULL,"dateLastUpdated" TIMESTAMP NOT NULL,"deleted" BOOLEAN NOT NULL,"online" BOOLEAN NOT NULL,"activeStatus" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"fileName" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"pubDate" DATE NOT NULL,"pubType" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"showcase" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"source" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"summary" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"title" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"attachment" VARCHAR(40) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"category" VARCHAR(40) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"worker" VARCHAR(40) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,CHECK((PUBLIC."publication"."activeStatus") IN (('ACTIVE'),('NOT_ACTIVE'))),CHECK((PUBLIC."publication"."pubType") IN (('BOOK'),('WORK_RELATED_ARTICLE'),('SELF_REVIEW_ARTICLE'),('THIRD_PARTY_REVIEW_ARTICLE'))),CHECK((PUBLIC."publication"."showcase") IN (('YES'),('NO'))),CONSTRAINT "UKhrpbkrd9xdsanblrx1ukd670e" UNIQUE("attachment"),CONSTRAINT "FKsf0mrpk9b2xprjf5xl5sxc3kj" FOREIGN KEY("attachment") REFERENCES PUBLIC."attachment"("id"),CONSTRAINT "FK6on23e0u4sl2wob81gal7gw5n" FOREIGN KEY("category") REFERENCES PUBLIC."category"("id"))
