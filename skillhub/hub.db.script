CREATE MEMORY TABLE PUBLIC."user"("id" VARCHAR(40) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL PRIMARY KEY,"dateCreated" TIMESTAMP NOT NULL,"dateLastUpdated" TIMESTAMP NOT NULL,"deleted" BOOLEAN NOT NULL,"online" BOOLEAN NOT NULL,"activeStatus" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"address" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"city" VARCHAR(72) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"country" VARCHAR(32) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"dateOfBirth" DATE,"email" VARCHAR(128) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"firstName" VARCHAR(32) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"lastName" VARCHAR(80) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"middleName" VARCHAR(32) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"mobilePhone" VARCHAR(16) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"nationalId" VARCHAR(32) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"profile" VARCHAR(512) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"showcase" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC NOT NULL,"verified" VARCHAR(255) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,"picture" VARCHAR(40) COLLATE INFORMATION_SCHEMA.SQL_TEXT_UCC,CHECK((PUBLIC."user"."activeStatus") IN (('ACTIVE'),('NOT_ACTIVE'))),CHECK((PUBLIC."user"."showcase") IN (('YES'),('NO'))),CHECK((PUBLIC."user"."verified") IN (('YES'),('NO'))),CONSTRAINT "UK31cmqyynx55vj9dwjmkb0qtey" UNIQUE("picture"),CONSTRAINT "FKfrxa4agye0lmq4yd91mbgerr1" FOREIGN KEY("picture") REFERENCES PUBLIC."attachment"("id"))
